# Copy to .env for local development. All values below match docker-compose defaults.

# Postgres (docker compose service)
DATABASE_URL=postgres://buddy:buddy@localhost:5432/buddy_pass

# API
PORT=3000
# Comma-separated allowed CORS origins (defaults to reflecting the request origin in dev)
# CORS_ORIGIN=http://localhost:5173

# Auth (better-auth). Generate a real secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=dev-only-change-me-0123456789abcdefghijk
# Public URL the api considers its own origin (defaults to http://localhost:3000)
# BETTER_AUTH_URL=http://localhost:3000
# Public web origin: CSRF trusted origin + base for minted /s/ and /f/ link URLs
# APP_ORIGIN=http://localhost:5173
